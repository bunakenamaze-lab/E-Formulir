# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://formulir.pcnubandung.or.id

# Development: berbeda domain → isi FRONTEND_URL
# Production fullstack: kosongkan (tidak perlu)
FRONTEND_URL=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/pcnu_forms"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti-dengan-random-string-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-random-string-minimal-32-karakter-lain
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email@gmail.com
SMTP_PASS=app-password
EMAIL_FROM=noreply@domain.or.id

# ─── Storage ──────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=200

# ─── Full-stack ───────────────────────────────────────────────────────────────
FULLSTACK=true
